# Backend security
SENTINEL_API_KEYS=secure-demo-key
SENTINEL_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
SENTINEL_RATE_LIMIT_PER_MINUTE=120
SENTINEL_MAX_BODY_BYTES=32768
SENTINEL_EXPOSE_DOCS=true
SENTINEL_ENABLE_API_NEWS_SOURCES=true

# Optional live-news API keys (enable broad leading-channel aggregation)
SENTINEL_NEWSAPI_KEY=
SENTINEL_GNEWS_KEY=
SENTINEL_GUARDIAN_KEY=
SENTINEL_NYT_KEY=
SENTINEL_MEDIASTACK_KEY=
SENTINEL_LIVE_QUERY=Strait of Hormuz OR GCC oil export OR LNG shipping disruption

# Frontend runtime
SENTINEL_BACKEND_URL=http://localhost:8000
SENTINEL_API_KEY=secure-demo-key
